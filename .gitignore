# Dependencies
node_modules/

# Build output
dist/
*.tsbuildinfo

# Generated intermediate content — DERIVED FROM COPYRIGHTED GAME DATA.
# Never commit. Each user generates this from their own owned copy via the asset pipeline.
# Anchored to the repo root (leading slash) so it ONLY ignores the top-level game-asset output,
# NOT source directories that happen to be named `content` (e.g. packages/app/src/content/).
/content/
!/content/.gitkeep

# Never commit original game assets / binaries, even if copied in by accident.
*.bmd
*.cif
*.hlt
*.pcx
*.lib
*.sgt
*.dls
*.fnt
*.wav
*.cur
map.dat
*.exe
*.dll

# Local configuration and credentials
.env
.env.*
!.env.example
*.key
*.pem
*.p12
*.pfx

# OS / editor / local agent tooling
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json

# Agent tooling: shared project config is tracked so it reaches every checkout/worktree; local state
# stays untracked. Use `/<tool>/*` + negations, NOT a bare `/<tool>/` (a fully-ignored dir can't have
# tracked children).
/.claude/*
!/.claude/commands/
!/.claude/agents/
!/.claude/workflows/
!/.claude/settings.json
/.gemini/*
!/.gemini/settings.json
/.cursor/*
!/.cursor/commands/

# Browser-automation artifacts (acceptance-scene verification, screenshots, console dumps).
# Root-anchored on purpose: committed documentation images live under docs/images/ and stay tracked.
.playwright-mcp/
/*.png


# Logs
*.log
npm-debug.log*
