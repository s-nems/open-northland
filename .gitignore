# Dependencies
node_modules/

# Build output
dist/
*.tsbuildinfo

# Generated intermediate content — DERIVED FROM COPYRIGHTED GAME DATA.
# Never commit. Each user generates this from their own owned copy via the asset pipeline.
# Anchored to the repo root (leading slash) so it ONLY ignores the top-level game-asset output,
# NOT source directories that happen to be named `content` (e.g. packages/app/src/content/).
/content/
!/content/.gitkeep

# Never commit original game assets / binaries, even if copied in by accident.
*.bmd
*.cif
*.hlt
*.pcx
*.lib
*.sgt
*.dls
*.exe

# OS / editor / local agent tooling
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json

# Agent tooling: the SHARED half (commands, agents, workflows, project hooks) is tracked — it is
# part of the project and must reach every checkout/worktree. Local state (settings.local.json,
# reports, locks) stays untracked. `/.claude/*` + negations, NOT a bare `.claude/` (a fully-ignored
# dir can't have tracked children).
/.claude/*
!/.claude/commands/
!/.claude/agents/
!/.claude/workflows/
!/.claude/settings.json

# Browser-automation artifacts (acceptance-scene verification, screenshots, console dumps)
.playwright-mcp/
/*.png


# Logs
*.log
npm-debug.log*
