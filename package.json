{
  "name": "open-northland",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Open-source cross-platform rebuild of Cultures - 8th Wonder of the World",
  "license": "GPL-3.0-or-later",
  "workspaces": [
    "packages/*",
    "tools/*"
  ],
  "scripts": {
    "build": "npm run typecheck && npm run build --workspace @open-northland/app",
    "clean": "tsc --build --clean",
    "typecheck": "tsc --build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:content": "node scripts/test-content.mjs",
    "test:pipeline": "node scripts/test-pipeline.mjs",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "check:assets": "node scripts/check-repository-assets.mjs",
    "dev": "npm run dev --workspace @open-northland/app",
    "dev:ports": "scripts/dev-ports.sh",
    "dev:reset": "scripts/dev-reset.sh",
    "scan:structure": "node scripts/structure-scan.mjs",
    "shot": "npm run shot --workspace @open-northland/app --",
    "pipeline": "npm run start --workspace @open-northland/asset-pipeline --"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "playwright": "^1.61.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
